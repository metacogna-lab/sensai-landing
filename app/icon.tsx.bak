import { ImageResponse } from 'next/og';

export const size = {
  width: 32,
  height: 32,
};
export const contentType = 'image/png';

export default function Icon() {
  return new ImageResponse(
    (
      <div
        style={{
          width: '100%',
          height: '100%',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          background: 'white',
          borderRadius: '50%',
          border: '2px solid black',
        }}
      >
        <span style={{ fontSize: '20px', fontWeight: 'bold' }}>〇</span>
      </div>
    ),
    { ...size }
  );
}
